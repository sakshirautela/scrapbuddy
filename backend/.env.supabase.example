# Copy this file to .env.supabase and fill values from Supabase:
# Supabase Dashboard -> Project Settings -> Database -> Connection string.

SPRING_PROFILES_ACTIVE=supabase

# Recommended: use Supabase transaction pooler connection string for deployed apps.
# Example:
# jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_URL=jdbc:postgresql://<host>:<port>/<database>?sslmode=require
SUPABASE_DB_USERNAME=<username>
SUPABASE_DB_PASSWORD=<password>

JWT_SECRET=replace-with-your-base64-secret
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1
